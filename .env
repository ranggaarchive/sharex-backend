# Environment
NODE_ENV=development
PORT=3000

# Database (MySQL)
DATABASE_URL="mysql://root@localhost:3306/sharex_db"

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRES_IN=7d

# Cookie Encryption (AES-256-GCM)
COOKIE_ENCRYPTION_KEY=a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6

# Guard
GUARD_EXTENSION_ID=your-guard-extension-id-here
MAIN_EXTENSION_ID=your-main-extension-id-here

# Admin
ADMIN_EMAIL=admin@sharex.com
ADMIN_PASSWORD=admin123

# CORS
CORS_ORIGIN=http://localhost:3001
