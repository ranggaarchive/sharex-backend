generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Plan {
  FREE
  PRO
  PHANTOM
}

enum Category {
  STREAMING
  PRODUCTIVITY
  DESIGN
  MUSIC
  EDUCATION
  UTILITIES
}

enum CookieHealth {
  HEALTHY
  EXPIRED
  REFRESHING
  UNKNOWN
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

enum UserRole {
  USER
  ADMIN
}

enum LoginMethod {
  INJECT
  INVITE_LINK
  MANUAL
}

// ─── Users ───────────────────────────────────────────────
model User {
  id              String    @id @default(uuid())
  email           String    @unique
  password        String    // bcrypt hashed
  licenseKey      String?   @unique @map("license_key")
  role            UserRole  @default(USER)
  plan            Plan      @default(FREE)
  planExpiresAt   DateTime? @map("plan_expires_at")
  currentDeviceId String?   @map("current_device_id")
  banWarningCount Int       @default(0) @map("ban_warning_count")
  isActive        Boolean   @default(true) @map("is_active")
  
  // Referral System
  referralCode    String    @unique @map("referral_code")
  referredById    String?   @map("referred_by_id")
  balance         Int       @default(0)

  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  sessions          Session[]
  transactions      Transaction[]
  referredBy        User?               @relation("Referral", fields: [referredById], references: [id])
  referrals         User[]              @relation("Referral")
  withdrawals       Withdrawal[]
  walletTransactions WalletTransaction[]

  @@map("users")
}

// ─── Domains (Services like Netflix, ChatGPT, etc) ──────
model Domain {
  id           String   @id @default(uuid())
  name         String   // "Netflix"
  slug         String   @unique // "netflix"
  url          String   // "https://www.netflix.com"
  loginUrl     String?  @map("login_url") // "https://www.netflix.com/login"
  iconUrl      String?  @map("icon_url")
  category     Category @default(STREAMING)
  requiredPlan Plan     @default(FREE) @map("required_plan")
  loginMethod  LoginMethod @default(INJECT) @map("login_method")
  cookieDomain String   @map("cookie_domain") // ".netflix.com"
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  accounts Account[]

  @@map("domains")
}

// ─── Premium Accounts ───────────────────────────────────
model Account {
  id              String       @id @default(uuid())
  domainId        String       @map("domain_id")
  label           String       // "Netflix Akun 1"
  email           String       // login email for the premium account
  password        String       // encrypted password for the premium account
  inviteLink      String?      @map("invite_link") // URL for INVITE_LINK method
  cookies         Json?        // encrypted cookie array [{name, value, domain, path, ...}]
  localStorageData Json?       @map("local_storage_data") // encrypted local storage array [{key, value}]
  cookieHealth    CookieHealth @default(UNKNOWN) @map("cookie_health")
  lastHealthCheck DateTime?    @map("last_health_check")
  lastCookieSync  DateTime?    @map("last_cookie_sync")
  maxConcurrent   Int          @default(1) @map("max_concurrent")
  displayCloneCount Int        @default(1) @map("display_clone_count")
  isActive        Boolean      @default(true) @map("is_active")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  domain   Domain    @relation(fields: [domainId], references: [id], onDelete: Cascade)
  sessions Session[]

  @@map("accounts")
}

// ─── Active Sessions (who is using which account) ───────
model Session {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  accountId String   @map("account_id")
  startedAt DateTime @default(now()) @map("started_at")
  expiresAt DateTime @map("expires_at")
  isActive  Boolean  @default(true) @map("is_active")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// ─── Guard Heartbeats ───────────────────────────────────
model GuardHeartbeat {
  id          String   @id @default(uuid())
  extensionId String   @map("extension_id")
  fingerprint String?
  isValid     Boolean  @default(true) @map("is_valid")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("guard_heartbeats")
}

// ─── Transactions ────────────────────────────────────────
model Transaction {
  id            String            @id @default(uuid())
  userId        String            @map("user_id")
  plan          Plan
  durationDays  Int               @map("duration_days")
  amount        Int
  status        TransactionStatus @default(PENDING)
  paymentMethod String?           @map("payment_method")
  paymentUrl    String?           @map("payment_url")
  sessionId     String?           @map("session_id")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("transactions")
}

// ─── Referral & Wallet ───────────────────────────────────
enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum WalletTransactionType {
  EARNING
  WITHDRAWAL
  REFUND
}

model Withdrawal {
  id            String           @id @default(uuid())
  userId        String           @map("user_id")
  amount        Int
  status        WithdrawalStatus @default(PENDING)
  provider      String           // Gopay, Dana, Ovo, Bank Name
  accountNumber String           @map("account_number")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("withdrawals")
}

model WalletTransaction {
  id            String                @id @default(uuid())
  userId        String                @map("user_id")
  amount        Int
  type          WalletTransactionType
  description   String?
  referenceTxId String?               @map("reference_tx_id") // ID from Transaction or Withdrawal if applicable
  createdAt     DateTime              @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("wallet_transactions")
}

